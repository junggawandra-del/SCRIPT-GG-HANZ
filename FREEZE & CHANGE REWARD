function MenuMataUang()
    local m = gg.choice({"1. GOLD/COIN", "2. T-CASH", "3. SEMANGGI", "4. REGATTA TOKEN", "🔙 KEMBALI"}, nil, "MENU MATA UANG")
    
    if m == nil or m == 5 then 
        MenuKebutuhan() 
    elseif m == 1 then
        -- [ LOGIKA GOLD/COIN ]
        local items = gg.getListItems()
        if #items == 0 then
            gg.alert("Daftar simpanan kosong! Pastikan data sudah di-save ke list.")
            MenuMataUang()
            return
        end
        local input = gg.prompt({"MASUKAN NILAI COIN (Maks 100,000):"}, {[1]="0"}, {[1]="number"})
        if not input then MenuMataUang() return end
        local nilai_input = tonumber(input[1])
        if nilai_input > 100000 then
            gg.alert("Input terlalu besar! Maksimal adalah 100,000.")
            MenuMataUang()
            return
        end
        local edit_list = {}
        local count = 0
        for i, v in ipairs(items) do
            local name = v.name or ""
            local found = false
            if name == "HANZ DATA 1" then v.value = "696F630Ah" v.freeze = true found = true
            elseif name == "HANZ DATA 2" then v.value = "0000736Eh" v.freeze = true found = true
            elseif name == "HANZ DATA 3" or name == "HANZ DATA 4" or name == "HANZ DATA 5" or name == "HANZ DATA 6" then v.value = "00000000h" v.freeze = true found = true
            elseif name == "HANZ NILAI POINTER" then v.value = "0" v.freeze = true found = true
            elseif name == "HANZ NILAI" then v.value = tostring(nilai_input) v.freeze = true found = true
            end
            if found then count = count + 1 edit_list[count] = v end
        end
        if count > 0 then
            gg.setValues(edit_list)
            gg.addListItems(edit_list)
            gg.toast("✅ Berhasil mengubah " .. count .. " data HANZ.")
        else
            gg.toast("⚠️ Tidak ditemukan data dengan nama yang sesuai.")
        end
        MenuMataUang()

    elseif m == 2 then
        -- [ LOGIKA BARU T-CASH SESUAI PERMINTAAN ]
        gg.setVisible(false)
        local list = gg.getListItems()
        
        if #list == 0 then
            gg.setVisible(true)
            gg.alert("❌ Tidak ada data di Saved List! Pastikan data sudah di-save dan diberi nama.")
            MenuMataUang()
            return
        end

        local input = gg.prompt({
            "MASUKAN NILAI T-CASH (Maks 10,000):"
        }, {0}, {"number"})

        if not input then gg.setVisible(true) MenuMataUang() return end

        local nilai_user = tonumber(input[1])
        if nilai_user > 10000 then
            gg.setVisible(true)
            gg.alert("⚠️ Input melebihi batas! Maksimal adalah 10,000.")
            MenuMataUang()
            return
        end

        local updateList = {}
        local count = 0

        for i, item in ipairs(list) do
            if item.name == "HANZ DATA 1" then
                item.value = "73616308h"
                item.freeze = true
            elseif item.name == "HANZ DATA 2" then
                item.value = "00000068h"
                item.freeze = true
            elseif item.name == "HANZ DATA 3" then
                item.value = "00000000h"
                item.freeze = true
            elseif item.name == "HANZ DATA 4" then
                item.value = "00000000h"
                item.freeze = true
            elseif item.name == "HANZ DATA 5" then
                item.value = "00000000h"
                item.freeze = true
            elseif item.name == "HANZ DATA 6" then
                item.value = "00000000h"
                item.freeze = true
            elseif item.name == "HANZ NILAI POINTER" then
                item.value = 0
