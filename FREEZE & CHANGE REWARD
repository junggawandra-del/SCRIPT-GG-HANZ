function Main()
    -- Sembunyikan GG sebelum menjalankan logika
    gg.setVisible(false)
    
    -- [ LOGIKA SCRIPT 1 ]
    gg.setRanges(gg.REGION_C_ALLOC)
    gg.clearResults()

    gg.searchNumber("1970225964;1599361808;1936025667;65537", gg.TYPE_DWORD)

    if gg.getResultCount() > 0 then
        gg.refineNumber("1970225964", gg.TYPE_DWORD)
        local count = gg.getResultCount()
        local results = gg.getResults(count)
        local freezeList = {}

        for i, v in ipairs(results) do
            freezeList[i] = {
                address = v.address - 0x10, 
                flags = gg.TYPE_DWORD,
                value = 0,
                freeze = true
            }
        end
        gg.addListItems(freezeList)
        gg.setValues(freezeList)
        gg.toast("✅ System mendeteksi " .. count .. " Alamat")
    else
        gg.toast("⚠️ 1: Data tidak ditemukan")
    end

    -- [ JEDA 2 DETIK ]
    gg.sleep(2000)

    -- [ LOGIKA SCRIPT 2 ]
    gg.clearResults()
    gg.setRanges(gg.REGION_C_ALLOC)
    gg.searchNumber("29;1970225964;7631471::70", gg.TYPE_DWORD)

    if gg.getResultCount() > 0 then
        local r = gg.getResults(10)
        local baseAddress = 0

        for i, v in ipairs(r) do
            if v.value == 29 then
                baseAddress = v.address
                break
            end
        end

        if baseAddress ~= 0 then
            local targets = {}
            -- Baris 4 sampai 9 (HANZ DATA 1-6)
            for i = 1, 6 do
                local offset = (i + 3) * 4
                targets[i] = {address = baseAddress + offset, flags = gg.TYPE_DWORD, name = "HANZ DATA " .. i}
            end
            -- Baris 10 & 11
            targets[7] = {address = baseAddress + (10 * 4), flags = gg.TYPE_DWORD, name = "HANZ NILAI POINTER"}
            targets[8] = {address = baseAddress + (11 * 4), flags = gg.TYPE_DWORD, name = "HANZ NILAI"}

            local results2 = gg.getValues(targets)
            for i = 1, #results2 do
                if i == 7 then
                    -- Simpan nilai asli pointer
                    results2[i].freeze = true
                end
                results2[i].name = targets[i].name
            end
            gg.addListItems(results2)
            gg.toast("✅ 2 Selesai: Data Disimpan")
        end
    else
        gg.toast("⚠️ Logika 2: Data tidak ditemukan")
    end

    -- Tampilkan kembali GG setelah logika selesai
    gg.setVisible(true)
    MenuUtama()
end

