-- Fungsi untuk mengambil script dari GitHub
function LoadOnline(url, name)
    gg.toast("⏳ Memuat data " .. name .. "...")
    local req = gg.makeRequest(url).content
    if req ~= nil and req ~= "" then
        local script, err = load(req)
        if script then
            script()
        else
            gg.alert("❌ Gagal menjalankan script " .. name .. ":\n" .. tostring(err))
        end
    else
        gg.alert("❌ Gagal mengambil data dari GitHub.\nPeriksa koneksi internet atau link: " .. name)
    end
end

