function Main()
    -- MODIFIKASI: TAMPILAN MENU UTAMA SESUAI IDENTITAS
    local info_header = T[lang].title .. "\n" .. CP_LINE .. 
                        "\n🎮 GAME  : TOWNSHIP" ..
                        "\n👤 OWNER : HANZ" ..
                        "\n🛰️ STATUS : ONLINE" ..
                        "\n💎 " .. DISPLAY_USER_TYPE .. "  : " .. SESSION_USER .. "\n" .. CP_LINE
                        
    local menu = gg.choice({"💎 " .. T[lang].m1, "⚡ " .. T[lang].m2, "🚀 " .. T[lang].m3, "✉️ " .. T[lang].m4, "❌ " .. T[lang].m5}, nil, info_header)

    if menu == 1 then ResetMisiRegeta() end
    if menu == 2 then IsiEnergyBiru() end
    if menu == 3 then ExpUpLevel() end
    if menu == 4 then KirimPesanHanz() end
    if menu == 5 then ExitScript() end
end

function ResetMisiRegeta()
    SendToDiscord("Executed: Reset Misi Regeta", WEBHOOK_MONITOR)
    ActionLoading(T[lang].t1, 1000)
    ActionLoading(T[lang].t2, 2000)
    gg.timeJump(-86400) 
    ActionLoading(T[lang].wait, 3000)
    gg.timeJump(86400)
    ActionLoading(T[lang].t4, 1000)
    gg.setVisible(true) 
end

function IsiEnergyBiru()
    SendToDiscord("Executed: Isi Energy Biru", WEBHOOK_MONITOR)
    ActionLoading(T[lang].t1, 1000)
    ActionLoading(T[lang].t2, 2000)
    gg.timeJump(36000) 
    ActionLoading(T[lang].wait, 3000)
    gg.timeJump(-35998)
    ActionLoading(T[lang].t4, 1000)
    gg.setVisible(true) 
end

function ExpUpLevel()
    local t = gg.prompt({"✨ 🌸 " .. T[lang].input_exp .. " 🌸 ✨\n" .. CP_LINE}, {200}, {"number"})
    if not t then return end
    SendToDiscord("Executed: Exp Up Level (Input: "..t[1]..")", WEBHOOK_MONITOR)
    ActionLoading(T[lang].t1, 1500)
    gg.clearResults()
    gg.setRanges(gg.REGION_C_ALLOC)
    gg.searchNumber("120;300", gg.TYPE_FLOAT)
    gg.refineNumber("120", gg.TYPE_FLOAT)
    local count = gg.getResultCount()
    if count == 0 then gg.toast("❌ 120 Not Found!") return end
    local r = gg.getResults(count)
    local editList = {}
    for i, v in ipairs(r) do
        local check = gg.getValues({{address = v.address + 4, flags = gg.TYPE_DWORD}})
        if check[1].value == 1 then
            table.insert(editList, {address = v.address + 16, flags = gg.TYPE_DWORD, value = 0, freeze = true})
            table.insert(editList, {address = v.address + 20, flags = gg.TYPE_DWORD, value = t[1], freeze = true})
        end
    end
    if #editList > 0 then
        gg.addListItems(editList)
        gg.setValues(editList)
        ActionLoading(T[lang].t4, 1000)
    else
        gg.toast("❌ No matching sequence!")
    end
    gg.setVisible(true)
end

function ExitScript()
    if not HAS_SENT_FEEDBACK then
        gg.alert(T[lang].exit_warn)
        KirimPesanHanz()
        if not HAS_SENT_FEEDBACK then return end
    end

    SendToDiscord("User closed script.", WEBHOOK_ENDED)
    gg.toast("🌸 Cleaning up HNZ Project assets...")
    gg.clearList()    
    gg.clearResults() 
    ActionLoading("Closing System", 1000)
    print("🌸 PINK EDITION V1.0 CLOSED SUCCESSFULLY")
    os.exit()
end

